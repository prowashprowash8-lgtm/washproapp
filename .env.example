# Stripe : pas de variable ici. Les clés sont dans Supabase → Project Settings →
# Edge Functions → Secrets : STRIPE_SECRET_KEY (sk_test_… en test, sk_live_… en prod)
# et STRIPE_WEBHOOK_SECRET (whsec_… du webhook Stripe correspondant au même mode test/live).

# Supabase - Récupérez ces valeurs dans le dashboard Supabase
# https://app.supabase.com → Votre projet → Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_publique

# Test : masquer une machine sur l’écran « Choisir une machine » (UUIDs séparés par des virgules)
# EXPO_PUBLIC_HIDDEN_MACHINE_IDS=

# Notifications push (optionnel) - Ajouté automatiquement par "npx eas init"
# Sinon, créez un projet sur https://expo.dev et copiez le projectId ici
# EXPO_PUBLIC_EAS_PROJECT_ID=votre-uuid
