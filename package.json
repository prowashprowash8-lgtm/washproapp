{
  "name": "washproapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "postinstall": "node ./scripts/ensure-debug.cjs && node ./scripts/fix-metro-file-map.cjs",
    "start": "env -u CI node ./scripts/expo-with-polyfill.cjs start --lan",
    "start:lan-ip": "env -u CI node ./scripts/start-lan-explicit.cjs",
    "start:clear": "env -u CI node ./scripts/expo-with-polyfill.cjs start --lan -c",
    "start:tunnel": "env -u CI node ./scripts/expo-with-polyfill.cjs start --tunnel -c",
    "start:go": "env -u CI node ./scripts/expo-with-polyfill.cjs start --tunnel -c",
    "tunnel:help": "node ./scripts/tunnel-help.cjs",
    "android": "env -u CI node ./scripts/expo-with-polyfill.cjs start --android",
    "ios": "env -u CI node ./scripts/expo-with-polyfill.cjs start --ios",
    "web": "env -u CI node ./scripts/expo-with-polyfill.cjs start --web --host localhost",
    "expo-cli": "env -u CI node ./scripts/expo-with-polyfill.cjs",
    "expo:lan-url": "node ./scripts/expo-lan-url.cjs",
    "check:expo": "node ./scripts/check-expo-connection.cjs",
    "diagnose:lan": "node ./scripts/diagnose-lan.cjs",
    "android:usb": "bash ./scripts/android-usb-reverse.sh",
    "eas:init": "npx eas-cli@latest init",
    "clean-install": "rm -rf node_modules && npm install"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@react-navigation/stack": "^7.8.4",
    "@supabase/supabase-js": "^2.99.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "expo": "^54.0.0",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "is-docker": "^3.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "shebang-regex": "^3.0.0"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
